# Flask/session security
IQC_ENV=production
IQC_SECRET_KEY=change-this-to-a-long-random-value

# Database
# For SQLite on a persistent disk/volume:
IQC_DATA_DIR=/data
# Or use a managed database:
# DATABASE_URL=postgresql://user:password@host:5432/database

# Upload storage for inspection evidence photos.
# If omitted, uploads are stored under IQC_DATA_DIR/uploads or backend/uploads.
IQC_UPLOAD_DIR=/data/uploads

# Initial production admin for a new empty database.
IQC_ADMIN_USERNAME=admin_iqc
IQC_ADMIN_PASSWORD=change-this-before-first-deploy
IQC_ADMIN_NAME=IQC Administrator

# Keep false in production. Set true only for local/demo databases.
IQC_SEED_DEMO_USERS=false

# Web Push notifications. Generate your own VAPID pair before production use.
IQC_VAPID_PUBLIC_KEY=
IQC_VAPID_PRIVATE_KEY=
IQC_VAPID_SUBJECT=mailto:iqc-platform@example.com
